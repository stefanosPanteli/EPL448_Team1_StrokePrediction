   "source": [
    "---\n",
    "\n",
    "# Pre-processed dataset versions"
   ]
  },
  {
   "cell_type": "code",
   "id": "e37109574dd55f6",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-04T08:52:40.219737900Z",
     "start_time": "2026-03-04T08:52:40.201110Z"
    }
   },
   "source": [
    "log1p = FunctionTransformer(lambda x: np.log1p(x), feature_names_out=\"one-to-one\")\n",
    "\n",
    "# ---------- Version A: Baseline (median impute, no scaling) ----------\n",
    "numeric_A = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "])\n",
    "\n",
    "preprocess_A = ColumnTransformer(transformers=[\n",
    "    (\"num\", numeric_A, numeric_features),\n",
    "    (\"bin\", \"passthrough\", binary_features),\n",
    "    (\"cat\", categorical_pipe, categorical_features),\n",
    "])\n",
    "\n",
    "# ---------- Version B: Robust scaling (median impute + RobustScaler) ----------\n",
    "numeric_B = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "    (\"scaler\", RobustScaler()),\n",
    "])\n",
    "\n",
    "preprocess_B = ColumnTransformer(transformers=[\n",
    "    (\"num\", numeric_B, numeric_features),\n",
    "    (\"bin\", \"passthrough\", binary_features),\n",
    "    (\"cat\", categorical_pipe, categorical_features),\n",
    "])\n",
    "\n",
    "# ---------- Version C: Unskew + Standardize (median + log1p + StandardScaler) ----------\n",
    "numeric_C = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "    (\"log1p\", log1p),\n",
    "    (\"scaler\", StandardScaler()),\n",
    "])\n",
    "\n",
    "preprocess_C = ColumnTransformer(transformers=[\n",
    "    (\"num\", numeric_C, numeric_features),\n",
    "    (\"bin\", \"passthrough\", binary_features),\n",
    "    (\"cat\", categorical_pipe, categorical_features),\n",
    "])\n",
    "\n",
    "# ---------- Version D: KNN Imputation + Robust scaling ----------\n",
    "numeric_D = Pipeline(steps=[\n",
    "    (\"imputer\", KNNImputer(n_neighbors=5)),\n",
    "    (\"scaler\", RobustScaler()),\n",
    "])\n",
    "\n",
    "preprocess_D = ColumnTransformer(transformers=[\n",
    "    (\"num\", numeric_D, numeric_features),\n",
    "    (\"bin\", \"passthrough\", binary_features),\n",
    "    (\"cat\", categorical_pipe, categorical_features),\n",
    "])\n",
    "\n",
    "# ---------- Version E: Outlier handling (median + QuantileClipper + RobustScaler) ----------\n",
    "numeric_E = Pipeline(steps=[\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "    (\"clip\", QuantileClipper(low=0.01, high=0.99)),  # handles extreme values\n",
    "    (\"scaler\", RobustScaler()),\n",
    "])\n",
    "\n",
    "preprocess_E = ColumnTransformer(transformers=[\n",
    "    (\"num\", numeric_E, numeric_features),\n",
    "    (\"bin\", \"passthrough\", binary_features),\n",
    "    (\"cat\", categorical_pipe, categorical_features),\n",
    "])"
   ],
   "outputs": [],
   "execution_count": 22
  },
  {
   "cell_type": "code",
   "id": "92edc23b3653cb71",
   "metadata": {
    "ExecuteTime": {
