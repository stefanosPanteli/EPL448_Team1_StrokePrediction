    "categorical_columns = ['gender', 'hypertension', 'heart_disease', 'ever_married', 'work_type', 'Residence_type', 'smoking_status']\n",
    "spacer = pd.DataFrame([{'column': '', 'category': '', 'count': '', 'percent': ''}])\n",
    "summary_parts = []\n",
    "\n",
    "for col in categorical_columns:\n",
