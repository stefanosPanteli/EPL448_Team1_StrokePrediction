   "source": [
    "def make_version(preprocessor, X_train, X_test, name):\n",
    "    Xtr = preprocessor.fit_transform(X_train)\n",
    "    Xte = preprocessor.transform(X_test)\n",
    "    print(f\"{name}: X_train {Xtr.shape} | X_test {Xte.shape}\")\n",
    "    return Xtr, Xte, preprocessor\n",
    "\n",
    "\n",
    "nicely_print(\"Generate Preprocessed Versions\", \"Fit on train only (no leakage)\")\n",
    "\n",
    "X_train_A, X_test_A, prep_A = make_version(preprocess_A, X_train, X_test, \"Version A (median + OHE)\")\n",
    "X_train_B, X_test_B, prep_B = make_version(preprocess_B, X_train, X_test, \"Version B (median + RobustScaler + OHE)\")\n",
    "X_train_C, X_test_C, prep_C = make_version(preprocess_C, X_train, X_test,\n",
    "                                           \"Version C (median + log1p + StandardScaler + OHE)\")\n",
    "X_train_D, X_test_D, prep_D = make_version(preprocess_D, X_train, X_test, \"Version D (KNNImputer + RobustScaler + OHE)\")\n",
    "X_train_E, X_test_E, prep_E = make_version(preprocess_E, X_train, X_test,\n",
    "                                           \"Version E (median + QuantileClip + RobustScaler + OHE)\")"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\u001B[1m\u001B[4m\u001B[96mGenerate Preprocessed Versions\u001B[0m \u001B[1mFit on train only (no leakage)\u001B[0m\n",
      "\n",
      "Version A (median + OHE): X_train (4088, 21) | X_test (1022, 21)\n",
      "Version B (median + RobustScaler + OHE): X_train (4088, 21) | X_test (1022, 21)\n",
      "Version C (median + log1p + StandardScaler + OHE): X_train (4088, 21) | X_test (1022, 21)\n",
      "Version D (KNNImputer + RobustScaler + OHE): X_train (4088, 21) | X_test (1022, 21)\n",
      "Version E (median + QuantileClip + RobustScaler + OHE): X_train (4088, 21) | X_test (1022, 21)\n"
     ]
    }
   ],
   "execution_count": 23
