   "source": [
    "nicely_print(\"Data Cleaning\", \"Deterministic cleaning only (no leakage)\")\n",
    "\n",
    "df_clean = df.copy()\n",
    "\n",
    "# 1) Drop id column (identifier)\n",
    "df_clean = df_clean.drop(columns=[\"id\"], errors=\"ignore\")\n",
    "\n",
    "# 2) Standardize missing markers for categorical/text columns only\n",
    "text_cols = df_clean.select_dtypes(include=[\"object\", \"string\"]).columns\n",
    "missing_markers = [\"N/A\", \"n/a\", \"NA\", \"na\", \"\"]\n",
    "df_clean[text_cols] = df_clean[text_cols].replace(missing_markers, np.nan)\n",
    "\n",
    "# 3) Trim whitespace safely and keep pandas <NA>\n",
    "for c in text_cols:\n",
    "    df_clean[c] = df_clean[c].astype(\"string\").str.strip()\n",
    "\n",
    "# 4) Normalize categorical values (lowercase + consistent separators) for known categorical columns\n",
    "norm_cols = [\"gender\", \"ever_married\", \"work_type\", \"Residence_type\", \"smoking_status\"]\n",
    "for c in norm_cols:\n",
    "    if c in df_clean.columns:\n",
    "        s = df_clean[c].astype(\"string\").str.lower().str.strip()\n",
    "        if c in {\"work_type\", \"smoking_status\"}:\n",
    "            s = (\n",
    "                s.str.replace(\"-\", \"_\", regex=False)\n",
    "                .str.replace(\" \", \"_\", regex=False)\n",
    "            )\n",
    "        df_clean[c] = s\n",
    "\n",
    "# 5) Type conversion (numeric + binary + target)\n",
    "num_cols = [\"age\", \"avg_glucose_level\", \"bmi\", \"hypertension\", \"heart_disease\", \"stroke\"]\n",
    "for c in num_cols:\n",
    "    if c in df_clean.columns:\n",
    "        df_clean[c] = pd.to_numeric(df_clean[c], errors=\"coerce\")\n",
    "\n",
    "# 6) Remove duplicated records\n",
    "df_clean = df_clean.drop_duplicates().reset_index(drop=True)\n",
    "\n",
    "# 7) Report missing values\n",
    "missing = df_clean.isna().sum().sort_values(ascending=False)\n",
    "print(\"Missing values > 0:\")\n",
    "display(missing[missing > 0])\n",
    "\n",
    "df_clean\n"
   ],
