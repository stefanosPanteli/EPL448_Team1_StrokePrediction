   "source": [
    "class QuantileClipper(BaseEstimator, TransformerMixin): # TODO: what is this\n",
    "    \"\"\"\n",
    "    Clips each numeric feature to train-set quantile bounds.\n",
    "    Fit learns bounds on TRAIN only => no leakage.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, low=0.01, high=0.99):\n",
    "        self.low = low\n",
    "        self.high = high\n",
    "\n",
    "    def fit(self, X, y=None):\n",
    "        X = np.asarray(X, dtype=float)\n",
    "        self.low_ = np.nanquantile(X, self.low, axis=0)\n",
    "        self.high_ = np.nanquantile(X, self.high, axis=0)\n",
    "        return self\n",
    "\n",
    "    def transform(self, X):\n",
    "        X = np.asarray(X, dtype=float)\n",
    "        return np.clip(X, self.low_, self.high_)"
   ],
   "outputs": [],
   "execution_count": 20
  },
  {
   "cell_type": "code",
   "id": "b8418cee408d29dd",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-04T08:52:40.194293600Z",
     "start_time": "2026-03-04T08:52:40.172298500Z"
    }
   },
   "source": [
    "# Categorical preprocessing pipeline:\n",
    "# 1) Fill missing categorical values using the most frequent value per column.\n",
    "# 2) One-hot encode categories, ignoring unseen categories in test/inference data.\n",
    "categorical_pipe = Pipeline(steps=[ # TODO: what is this\n",
    "    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "    (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\"))\n",
    "])"
   ],
   "outputs": [],
   "execution_count": 21
  },
